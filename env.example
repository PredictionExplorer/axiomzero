# Wallets
# Required for live wallet connection. If omitted, Vercel builds still deploy
# but WalletConnect QR and mobile wallet support may not work reliably.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://axiomzero.market

# Arbitrum RPC
# In production, point ARBITRUM_RPC_URL at a dedicated provider endpoint
# (Alchemy, Infura, QuickNode, ...). The default public endpoint rate-limits
# shared hosting IPs, which intermittently breaks the on-chain offer scans and
# renders N/A floor/bid stats into cached pages.
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Existing Random Walk backend used by randomwalknft.com
RANDOM_WALK_SITE_URL=https://randomwalknft.com
NEXT_PUBLIC_RANDOM_WALK_SITE_URL=https://randomwalknft.com
RANDOM_WALK_API_URL=https://api.randomwalknft.com:1443
NEXT_PUBLIC_RANDOM_WALK_API_URL=https://api.randomwalknft.com:1443

# Collection contracts on Arbitrum
NEXT_PUBLIC_RANDOM_WALK_NFT_ADDRESS=0x895a6F444BE4ba9d124F61DF736605792B35D66b
NEXT_PUBLIC_RANDOM_WALK_MARKETPLACE_ADDRESS=0x47eF85Dfb775aCE0934fBa9EEd09D22e6eC0Cc08
NEXT_PUBLIC_COSMIC_SIGNATURE_NFT_ADDRESS=0xbb84Be3500A63581d3F2d5AC3bdF8685AAedad25
NEXT_PUBLIC_COSMIC_SIGNATURE_MARKETPLACE_ADDRESS=0x47eF85Dfb775aCE0934fBa9EEd09D22e6eC0Cc08

# Cosmic Signature anchoring wallets (one-time anchor usage per token).
# Published at https://app.cosmicsignature.com/contracts
NEXT_PUBLIC_RANDOM_WALK_ANCHORING_WALLET_ADDRESS=0x5EB3396092841E6c5b0b51141699F6711E830529
NEXT_PUBLIC_COSMIC_SIGNATURE_ANCHORING_WALLET_ADDRESS=0x6308A405B4FF1eA890870Efe2a6D036750B81F7C

# Frontend discovery and wallet-inventory scan bounds
NEXT_PUBLIC_RANDOM_WALK_MAX_TOKEN_ID=4085
NEXT_PUBLIC_COSMIC_SIGNATURE_MAX_TOKEN_ID=23

# Server-side marketplace reads
MARKETPLACE_SCAN_LIMIT=5000
